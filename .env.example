LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...  # or gsk-... (Groq), sk-... (DeepSeek), etc.
OPENAI_BASE_URL=       # optional: e.g. https://api.groq.com/openai/v1
OPENAI_MODEL=          # optional: e.g. llama-3.1-8b-instant (default: gpt-4o-mini)
QUESTION_TIMER_SECONDS=180
OLLAMA_API_KEY=        # API key for Ollama endpoint
OLLAMA_BASE_URL=       # optional: Ollama OpenAI-compatible endpoint (default: http://localhost:11434/v1)
OLLAMA_MODEL=          # optional: Ollama model name (default: llama3.2:3b)
